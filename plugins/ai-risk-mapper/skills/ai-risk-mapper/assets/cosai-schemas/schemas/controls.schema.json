{
  "$id": "controls.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CoSAI-RM Controls Schema",
  "description": "Schema for validating YAML-based controls definition",
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "description": { "$ref": "riskmap.schema.json#/definitions/utils/text" },
    "categories": {
      "type": "array",
      "items": { "$ref": "#/definitions/category" }
    },
    "controls": {
      "type": "array",
      "items": { "$ref": "#/definitions/control" }
    }
  },
  "required": ["title", "description", "categories", "controls"],
  "definitions": {
    "category": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "controlsData",
            "controlsInfrastructure",
            "controlsModel",
            "controlsApplication",
            "controlsAssurance",
            "controlsGovernance"
          ]
        },
        "title": { "type": "string" }
      },
      "required": ["id", "title"]
    },
    "control": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "controlAdversarialTrainingAndTesting",
            "controlAgentPluginPermissions",
            "controlAgentPluginUserControl",
            "controlAgentObservability",
            "controlApplicationAccessManagement",
            "controlIncidentResponseManagement",
            "controlInputValidationAndSanitization",
            "controlInternalPoliciesAndEducation",
            "controlIsolatedConfidentialComputing",
            "controlModelAndDataAccessControls",
            "controlModelAndDataExecutionIntegrity",
            "controlModelAndDataIntegrityManagement",
            "controlModelAndDataInventoryManagement",
            "controlModelPrivacyEnhancingTechnologies",
            "controlOrchestratorAndRouteIntegrity",
            "controlOutputValidationAndSanitization",
            "controlProductGovernance",
            "controlRedTeaming",
            "controlRetrievalAndVectorSystemIntegrity",
            "controlRiskGovernance",
            "controlRuntimePrivacyEnhancingTechnologies",
            "controlSecureByDefaultMLTooling",
            "controlThreatDetection",
            "controlTrainingDataManagement",
            "controlTrainingDataSanitization",
            "controlUserDataManagement",
            "controlUserPoliciesAndEducation",
            "controlUserTransparencyAndControls",
            "controlVulnerabilityManagement"
          ]
        },
        "title": { "type": "string" },
        "description": { "$ref": "riskmap.schema.json#/definitions/utils/text" },
        "category": { "$ref": "#/definitions/category/properties/id" },
        "personas": {
          "type": "array",
          "items": { "$ref": "personas.schema.json#/definitions/persona/properties/id" }
        },
        "components": {
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "components.schema.json#/definitions/component/properties/id" }
            },
            {
              "type": "string",
              "enum": ["all", "none"]
            }
          ]
        },
        "risks": {
          "oneOf": [
            {
              "type": "array",
              "items": { "$ref": "risks.schema.json#/definitions/risk/properties/id" }
            },
            {
              "type": "string",
              "enum": ["all"]
            }
          ]
        },
        "mappings": {
          "type": "object",
          "description": "Cross-references to external security frameworks. Per ADR-020 D5 + ADR-022 D5b: mitre-atlas, iso-22989, and eu-ai-act receive per-framework strict patterns from frameworks.schema.json; stride, nist-ai-rmf, and owasp-top10-llm fall through to the loose catch-all because their current entries use non-canonical forms. Keys must match valid framework IDs in frameworks.schema.json.",
          "propertyNames": {
            "$ref": "frameworks.schema.json#/definitions/framework/properties/id"
          },
          "properties": {
            "mitre-atlas": {
              "type": "array",
              "items": { "$ref": "frameworks.schema.json#/definitions/framework-mapping-patterns/properties/mitre-atlas" }
            },
            "iso-22989": {
              "type": "array",
              "items": { "$ref": "frameworks.schema.json#/definitions/framework-mapping-patterns/properties/iso-22989" }
            },
            "eu-ai-act": {
              "type": "array",
              "items": { "$ref": "frameworks.schema.json#/definitions/framework-mapping-patterns/properties/eu-ai-act" }
            }
          },
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "lifecycleStage": {
          "description": "AI system lifecycle phases where applicable",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "lifecycle-stage.schema.json#/definitions/lifecycleStage/properties/id"
              }
            },
            {
              "type": "string",
              "enum": ["all", "none"]
            }
          ]
        },
        "impactType": {
          "description": "Security, privacy, or safety impact categories",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "impact-type.schema.json#/definitions/impactType/properties/id"
              }
            },
            {
              "type": "string",
              "enum": ["all", "none"]
            }
          ]
        },
        "actorAccess": {
          "description": "Level of system access required by threat actor",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "actor-access.schema.json#/definitions/actorAccessLevel/properties/id"
              }
            },
            {
              "type": "string",
              "enum": ["all", "none"]
            }
          ]
        },
        "externalReferences": {
          "$ref": "external-references.schema.json#/definitions/externalReferences"
        }
      },
      "required": ["title", "description", "category", "personas", "components", "risks"]
    }
  }
}
