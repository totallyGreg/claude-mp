{
  "$id": "riskmap.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CoSAI-RM RiskMap Schema",
  "description": "Schema providing utility definitions",
  "definitions": {
    "utils": {
      "text": {
        "type": "array",
        "items": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            }
          ]
        }
      },
      "prose-strict": {
        "type": "array",
        "minItems": 1,
        "items": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          ]
        }
      }
    }
  }
}
