{
  "description": "Skill evaluation on SKILL.md edits; script policy enforcement on scripts/*.py edits",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/on-skill-edit.sh",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/on-script-edit.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
