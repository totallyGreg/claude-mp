{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ES2020",
    "outDir": "../build/intermediate",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "removeComments": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "ofo-core.ts",
    "ofo-core-ambient.d.ts",
    "../../typescript/omnifocus.d.ts",
    "../../typescript/omnifocus-extensions.d.ts"
  ],
  "exclude": ["node_modules"]
}
