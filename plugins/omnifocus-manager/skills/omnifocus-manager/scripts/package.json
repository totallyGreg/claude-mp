{
  "name": "omnifocus-plugin-generator",
  "version": "4.0.0",
  "description": "TypeScript-based OmniFocus plugin generator with LSP validation",
  "main": "generate_plugin.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:plugin && npm run build:cli",
    "build:generator": "tsc",
    "build:plugin": "bash build-plugin.sh",
    "build:cli": "tsc --project src/tsconfig.cli.json && cp src/ofo-stub.js build/ofo-stub.js",
    "deploy": "cp -r build/ofo-core.omnifocusjs \"$HOME/Library/Containers/com.omnigroup.OmniFocus4/Data/Library/Application Support/Plug-Ins/ofo-core.omnifocusjs\"",
    "watch": "tsc --watch",
    "generate": "node generate_plugin.js"
  },
  "keywords": [
    "omnifocus",
    "omni-automation",
    "plugin",
    "generator",
    "typescript"
  ],
  "author": "OmniFocus Manager Skill",
  "license": "MIT",
  "dependencies": {
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
